# This dynamics.settings.yml file makes drush site install fail. Ignoring it, for now at least.
# /config/default/dynamics.settings.yml

# Ignore directories generated by Composer
/drush/contrib/
/vendor/
/docroot/core/
/docroot/modules/contrib/
/docroot/themes/contrib/
/docroot/profiles/contrib/
/docroot/libraries/
/recipes/

# Ignore .htaccess and robots.txt
.htaccess
/docroot/robots.txt

# Ignore sensitive information
/docroot/sites/*/settings.local.php
/.env
.ddev/config.local.yaml
/.ddev/config.local.yaml
.ddev/.env

# Ignore DDEV Traefik generated certificates and configuration
.ddev/traefik/certs/*.crt
.ddev/traefik/certs/*.key
.ddev/traefik/config/

# Ignore Drupal's file directory
/docroot/sites/*/files/
/tmp
/private

# Ignore files generated by Drush
.drush

# Ignore SimpleTest multi-site environment.
/docroot/sites/simpletest

# Ignore files generated by PhpStorm
/.idea/

# Ignore OS generate files
.DS_Store

# Ignore most sql file variations
*.sql
*.sql.gz
*.sql.tgz
*.mysql
!used-files.sql
!dump-source.sql

# PHPUnit
.phpunit.result.cache

# Ignore IDE files
/.vscode
.lando.local.yml

# Ignore token auth
/auth.json

# Local scripts.
.scripts
